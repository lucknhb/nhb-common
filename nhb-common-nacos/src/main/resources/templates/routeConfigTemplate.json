{
  "id": "${serviceId}",
  "uri": "lb://${serviceId}",
  "predicates": [
    {
      "name": "Path",
      "args": {
        "pattern": "/${serviceId}/**"
      }
    },
    {
      "name": "Weight",
      "args": {
        "_genkey_0": "${serviceId}",
        "_genkey_1": "100"
      }
    }
  ],
  "filters": [
    {
      "name": "StripPrefix",
      "args": {
        "parts": "1"
      }
    },
    {
      "name": "RewritePath",
      "args": {
        "_genkey_0": "/${serviceId}/(?<path>.*)",
        "_genkey_1": "/$\\{path}"
      }
    }
  ],
  "metadata": {
    "version": "2.0"
  },
  "order": 1
}